# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for: Whisper (system audio fallback transcription) + GPT-4o (AI chat)
OPENAI_API_KEY=sk-...

# ── Google OAuth (optional — enables "Continue with Google") ──────────────────
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID of type "Desktop app"
# 3. Add http://localhost:43821/callback as an authorised redirect URI
# 4. Copy the Client ID and Secret here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
