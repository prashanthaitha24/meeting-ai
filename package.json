{
  "name": "meeting-ai",
  "version": "1.0.0",
  "description": "Real-time AI meeting assistant with local-first transcription",
  "main": "./out/main/index.js",
  "author": "Prashanth Aitha <prashanthaitha24@gmail.com>",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "dist:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "pack": "electron-vite build && electron-builder --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@supabase/supabase-js": "^2.102.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
